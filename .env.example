# OpenAI API Compatible settings (как в SillyTavern)
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=deepseek-v4-flash

# Agent mode: AI может писать несколько сообщений подряд,
# отключаться и переподключаться как живой человек
AGENT_ENABLED=false
AGENT_MAX_CONSECUTIVE=2
AGENT_IDLE_TIMEOUT=180
AGENT_RECONNECT_DELAY=60

# Telegram Bot (для bot.py)
BOT_TOKEN=your-telegram-bot-token-here
BOT_USE_PROXY=false
# Прокси для Telegram API (SOCKS5/HTTP). Работает только при BOT_USE_PROXY=true.
# BOT_PROXY_URL=socks5://user:pass@127.0.0.1:1080
